{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qtodo",
  "version": "0.1.7",
  "identifier": "com.y.qtodo",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "qtodo",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0OEI1QUNENUZFRjAxMUMKUldRY0FlOWZ6VnFMZEZBZW5JYzNhWWtsRXNEZlZsR0p3VkZIWlFDWHdoa2ZlY3dBRkRKdHRyQkUK",
      "endpoints": [
        "https://github.com/9ycrooked/Qtodo/releases/latest/download/latest.json"
      ]
    }
  }
}
